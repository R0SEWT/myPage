---
import ScrollReveal from '../ui/ScrollReveal.astro';
import Badge from '../ui/Badge.astro';
import { SITE_CONFIG, MAIN_TECHNOLOGIES } from '../../lib/constants';
import { getCollection } from 'astro:content';

const featured = (await getCollection('projects', p => p.data.featured === true))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---

<section id="home" class="relative overflow-hidden matrix-bg particles" role="banner" aria-labelledby="hero-heading">
  <div class="max-w-6xl mx-auto px-4 py-16 md:py-24 grid md:grid-cols-2 gap-10 items-center">
    <ScrollReveal>
      <div>
        <h1 id="hero-heading" class="hero-title text-3xl md:text-5xl font-bold leading-tight tracking-tight">
          Diseño sistemas de <span class="data-ai-box text-teal subtle-interference" aria-label="Machine Learning">ML</span> para producción
        </h1>
        <p class="mt-4 text-base md:text-lg text-slate-600 dark:text-slate-300">
          Applied ML Engineer. Construyo pipelines RAG, sistemas de document intelligence y flujos de datos bajo restricciones reales — API limits, documentos ruidosos, formatos heterogéneos. Actualmente en CIP (CGIAR).
        </p>
        <div class="mt-6 flex flex-wrap gap-3" role="group" aria-label="Enlaces principales">
          <a href="#projects" class="effect-button rounded-xl bg-slate-900 text-white dark:bg-white dark:text-slate-900 px-4 py-2 text-sm font-semibold focus-ring hover:opacity-90 transition-opacity" aria-label="Ver sistemas seleccionados">
            Ver sistemas
          </a>
          <a href={SITE_CONFIG.github} target="_blank" rel="noopener" class="effect-button rounded-xl border border-slate-200 dark:border-slate-800 px-4 py-2 text-sm font-semibold focus-ring hover:opacity-90 transition-opacity" aria-label="Ver perfil de GitHub (abre en nueva ventana)">
            GitHub
          </a>
        </div>
        <div class="mt-6 flex flex-wrap gap-2 text-xs text-slate-500" role="list" aria-label="Tecnologías principales">
          {MAIN_TECHNOLOGIES.map((tech) => (
            <Badge
              text={tech.text}
              variant={'variant' in tech ? tech.variant : undefined}
              animated={'animated' in tech ? tech.animated : undefined}
            />
          ))}
        </div>
      </div>
    </ScrollReveal>

    <ScrollReveal delay={200}>
      <div class="relative" role="img" aria-label="Vista previa de sistemas destacados">
        <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-teal to-lilac/70 p-[2px] shadow-xl animate-float">
          <div class="h-full w-full rounded-2xl p-6 flex items-center glass">
            <div class="grid grid-cols-2 gap-4 w-full">
              {featured.map((project) => (
                <div class="rounded-xl border border-slate-200 dark:border-slate-800 p-4 hover:border-teal/30 transition-colors" role="region" aria-label={project.data.title}>
                  <p class="text-xs text-slate-500">{project.data.heroLabel}</p>
                  <p class="font-semibold">{project.data.title.split(' — ')[0]}</p>
                  <p class="text-xs text-slate-500">{project.data.heroDescription}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
        <p class="mt-2 text-xs text-slate-500" aria-label="Nota: capturas de pantalla reales de proyectos"></p>
      </div>
    </ScrollReveal>
  </div>
</section>
