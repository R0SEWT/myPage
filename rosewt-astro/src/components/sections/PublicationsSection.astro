---
import { PUBLICATIONS } from '../../lib/constants';

export interface Publication {
  title: string;
  description: string;
  link?: string;
}
---

<section
  id="publications"
  class="py-16 md:py-24 bg-slate-50 dark:bg-slate-900/30"
>
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold">Investigación</h2>
    <ul class="mt-6 grid md:grid-cols-2 gap-4 text-sm">
      {
        PUBLICATIONS.map((pub) => (
          <li class="rounded-xl border border-slate-200 dark:border-slate-800 p-4 hover:bg-white/60 dark:hover:bg-slate-900/60 transition">
            {pub.link ? (
              <a href={pub.link} class="font-semibold hover:text-teal">
                {pub.title}
              </a>
            ) : (
              <span class="font-semibold">{pub.title}</span>
            )}
            <p class="text-slate-500">{pub.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
